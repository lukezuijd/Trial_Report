                       ))}
                    </div>
                    <div className="col-span-1 md:col-span-9 bg-white p-4 sm:p-8 rounded-xl shadow-sm border border-slate-100 space-y-8 overflow-hidden">
                       {groups.find(g => g.id === activeGroupId) && (
                         <>
                           <div>
                             <h3 className="font-bold text-lg mb-4 text-[#211A1A]">Trial Samples Config</h3>
                             <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mb-4">
                               <div><label className="label whitespace-nowrap">Name</label><input type="text" className="input font-bold" value={groups.find(g => g.id === activeGroupId).name || ''} onChange={(e) => handleGroupChange(activeGroupId, 'name', null, e.target.value)} /></div>
                               <div><label className="label whitespace-nowrap">Packaging Type</label><select className="input" value={groups.find(g => g.id === activeGroupId).specs.packaging || ''} onChange={(e) => handleGroupChange(activeGroupId, 'specs', 'packaging', e.target.value)}>{PACKAGING_TYPES.map(t => <option key={t}>{t}</option>)}</select></div>
                             </div>
                             
                             <label className="label text-blue-800 mb-2 border-b border-blue-200 pb-1 w-full block mt-4">Packaging Dimensions</label>
                             <div className="grid grid-cols-1 sm:grid-cols-3 gap-4 bg-slate-50 p-4 rounded-t-lg border-x border-t border-slate-100">
                                <div><label className="label whitespace-nowrap">Length (mm)</label><input type="number" className="input" value={groups.find(g => g.id === activeGroupId).specs.length || ''} onChange={(e) => handleGroupChange(activeGroupId, 'specs', 'length', e.target.value)} /></div>
                                <div><label className="label whitespace-nowrap">Width (mm)</label><input type="number" className="input" value={groups.find(g => g.id === activeGroupId).specs.width || ''} onChange={(e) => handleGroupChange(activeGroupId, 'specs', 'width', e.target.value)} /></div>
                                <div><label className="label whitespace-nowrap">Height (mm)</label><input type="number" className="input" value={groups.find(g => g.id === activeGroupId).specs.height || ''} onChange={(e) => handleGroupChange(activeGroupId, 'specs', 'height', e.target.value)} /></div>
                             </div>
                             <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 bg-slate-50 p-4 rounded-b-lg border border-slate-100 mb-6">
                               <div><label className="label whitespace-nowrap">Material</label><input className="input" value={groups.find(g => g.id === activeGroupId).specs.material || ''} onChange={(e) => handleGroupChange(activeGroupId, 'specs', 'material', e.target.value)} /></div>
                               <div><label className="label whitespace-nowrap">Transmission Value</label><input type="number" className="input" value={groups.find(g => g.id === activeGroupId).specs.holes || ''} onChange={(e) => handleGroupChange(activeGroupId, 'specs', 'holes', e.target.value)} /></div>
                               <div className="col-span-1 lg:col-span-1 mt-2 lg:mt-0"><label className="label whitespace-nowrap">Aantal Samples / Meting</label><input type="number" min="1" className="input w-full bg-white border-blue-200 font-bold text-blue-900" value={groups.find(g => g.id === activeGroupId).specs.sampleCount || 3} onChange={(e) => handleSampleCountChange(activeGroupId, parseInt(e.target.value))} /></div>
                             </div>
                             
                             <div className="border-2 border-dashed border-blue-200 bg-blue-50 rounded-lg p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                                <div className="flex items-center gap-4">
                                   <LineChart size={24} className="text-blue-500 shrink-0" />
                                   <div>
                                     <div className="font-bold text-sm text-blue-900">Predicted Gas Graph</div>
                                     <div className="text-xs text-blue-600">Upload screenshot for this variant</div>
                                   </div>
                                </div>
                                <label className="cursor-pointer bg-white border border-blue-200 text-blue-700 px-4 py-2 rounded font-bold text-xs hover:bg-blue-50 transition shrink-0 whitespace-nowrap">
                                   Upload Image
                                   <input 
                                     type="file" 
                                     accept="image/*" 
                                     className="hidden" 
                                     onClick={(e) => {
                                        const g = groups.find(x => x.id === activeGroupId);
                                        if (g && g.predictedImage) {
                                          e.preventDefault();
                                          setPendingImageReplace({ groupId: activeGroupId, result: null });
                                        }
                                     }}
                                     onChange={(e) => handlePredictedImageUpload(e, activeGroupId)} 
                                   />
                                </label>
                             </div>
                             {groups.find(g => g.id === activeGroupId).predictedImage && (
                                <div className="mt-2 border rounded p-2 bg-white inline-block max-w-full relative group">
                                  <img src={groups.find(g => g.id === activeGroupId).predictedImage} className="h-32 max-w-full object-contain" />
                                  <button onClick={() => handleGroupChange(activeGroupId, null, 'predictedImage', null)} className="absolute top-1 right-1 bg-red-500 text-white p-1 rounded-full opacity-0 group-hover:opacity-100 transition shadow-lg"><Trash2 size={12}/></button>
                                </div>
                             )}
                           </div>
                         </>
                       )}
                    </div>
                  </>
                )}

                {/* 3. PROPOSAL (Teksten) */}
                {activeTab === 'proposal' && (
                  <div className="col-span-12 space-y-6">
                    <div className="bg-white p-4 sm:p-8 rounded-xl shadow-sm border border-slate-100 grid grid-cols-1 md:grid-cols-2 gap-8">
                       <div className="md:col-span-2"><h2 className="font-bold text-lg border-b pb-2 mb-2 text-[#211A1A]">Voorstel & Evaluatieplan</h2></div>
                       
                       <div className="md:col-span-2">
                          <label className="label mb-2">Introductie / Huidige Uitdaging</label>
                          <RichTextEditor 
                             value={proposal.intro} 
                             onChange={(val) => setProposal(prev => ({...prev, intro: val}))} 
                             placeholder="Beschrijf de uitdaging en waarom we deze test uitvoeren..."
                          />
                       </div>
                       
                       <div className="md:col-span-2">
                          <label className="label mb-2">Doel / Verwachte Resultaten</label>
                          <RichTextEditor 
                             value={proposal.expectedOutcomes} 
                             onChange={(val) => setProposal(prev => ({...prev, expectedOutcomes: val}))} 
                             placeholder="Wat hopen we te bereiken met deze test?"
                          />
                       </div>
                       
                       <div className="md:col-span-2">
                          <label className="label mb-2">Benodigdheden & Afspraken (Requirements)</label>
                          <RichTextEditor 
                             value={proposal.requirements} 
                             onChange={(val) => setProposal(prev => ({...prev, requirements: val}))} 
                             placeholder="Wat moet de klant aanleveren? Welke afspraken zijn er gemaakt?"
                          />
                       </div>

                       <div className="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-6 mt-4">
                         <div>
                           <label className="label text-orange-600">Korte Samenvatting Uitdaging</label>
                           <textarea rows="3" className="input bg-orange-50 border-orange-200" value={project.currentChallenge} onChange={e => handleProjectChange('currentChallenge', e.target.value)} placeholder="(Optioneel) Korte bullet-points voor op blz 2" />
                         </div>
                         <div>
                           <label className="label text-green-600">Trial Target</label>
                           <textarea rows="3" className="input bg-green-50 border-green-200" value={project.trialTarget} onChange={e => handleProjectChange('trialTarget', e.target.value)} placeholder="(Optioneel) Kort doel voor op blz 2" />
                         </div>
                       </div>
                    </div>
                  </div>
                )}

              </main>
            </div>
          );
        };

        const root = createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
