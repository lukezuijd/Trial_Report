<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PerfoTec Proposal Tool</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Babel compiler voor in-browser React (JSX) -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        html { scroll-behavior: smooth; }
        body { background-color: #f8fafc; }
        
        .label { 
            display: block; font-size: 0.75rem; font-weight: 700; color: #64748b; 
            text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem; 
            font-family: 'Inter', sans-serif;
            white-space: nowrap;
        }
        .input { 
            width: 100%; padding: 0.6rem; border: 1px solid #e2e8f0; 
            border-radius: 0.5rem; outline: none; transition: 0.2s; 
            font-size: 0.9rem; font-family: 'Inter', sans-serif; 
        }
        .input:focus { 
            border-color: #007C27; box-shadow: 0 0 0 3px rgba(0, 124, 39, 0.1); 
        }
        
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=League+Spartan:wght@700&display=swap');
        .brand-heading { font-family: 'League Spartan', sans-serif; }
        .brand-body { font-family: 'Inter', sans-serif; }

        .rich-text-editor { min-height: 120px; }
        .rich-text-editor ul { list-style-type: disc; padding-left: 1.5rem; margin-top: 0.5rem; margin-bottom: 0.5rem; }
        .rich-text-editor li { margin-bottom: 0.25rem; }
        .rich-text-editor b { font-weight: 700; }
        .rich-text-editor i { font-style: italic; }
        .rich-text-editor u { text-decoration: underline; }
        [contenteditable]:empty:before { content: attr(data-placeholder); color: #94a3b8; pointer-events: none; display: block; }

        @media print {
            body { background-color: white !important; }
            .no-print { display: none !important; }
            #print-area { width: 100%; padding: 0; margin: 0; }
            .page-break { page-break-before: always; }
            .break-inside-avoid { break-inside: avoid; page-break-inside: avoid; }
            body * { visibility: hidden; }
            #print-content, #print-content * { visibility: visible; }
            #print-content { 
              position: absolute; left: 0; top: 0; width: 100%; 
              margin: 0; padding: 0; background: white; box-shadow: none; 
            }
            svg { break-inside: avoid; }
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        }
        
        .report-section-title { 
            color: #007C27; font-family: 'League Spartan', sans-serif; 
            font-size: 1.5rem; font-weight: bold; border-bottom: 2px solid #E9E9E9; 
            padding-bottom: 0.5rem; margin-bottom: 1rem; margin-top: 2rem; 
        }
        .report-table th { background-color: #007C27; color: white; padding: 8px; text-align: left; font-family: 'League Spartan', sans-serif; }
        .report-table td { border-bottom: 1px solid #E9E9E9; padding: 8px; font-family: 'Inter', sans-serif; font-size: 0.9rem; }
        
        .pdf-rich-text, .pdf-rich-text * { font-family: 'Inter', sans-serif !important; font-size: 0.875rem !important; color: #1e293b !important; line-height: 1.625 !important; }
        .pdf-rich-text b, .pdf-rich-text strong { font-weight: 700 !important; }
        .pdf-rich-text i, .pdf-rich-text em { font-style: italic !important; }
        .pdf-rich-text u { text-decoration: underline !important; }
        .pdf-rich-text ul { list-style-type: disc !important; padding-left: 1.5rem !important; margin-top: 0.5rem !important; margin-bottom: 0.5rem !important; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel" data-type="module">
        import React, { useState, useRef, useEffect } from 'https://esm.sh/react@18.2.0';
        import { createRoot } from 'https://esm.sh/react-dom@18.2.0/client';
        import { 
          Printer, FileText, Settings, Layout, CheckCircle, 
          ArrowRight, Copy, Trash2, Plus, Scale, Upload, Truck, 
          Thermometer, Clock, Image as ImageIcon, ChevronRight, 
          Save, FolderOpen, Tractor, Ship, Plane, Warehouse, Store, 
          Utensils, Factory, ArrowDown, ArrowUp, ChevronUp, ChevronDown, 
          Bold, Italic, Underline, List, AlertTriangle, Package,
          X, Edit3, Camera, FileArchive, LineChart
        } from 'https://esm.sh/lucide-react@0.292.0';

        // --- BRAND CONFIGURATIE ---
        const BRAND = {
          colors: {
            green: '#007C27', 
            blue: '#054E9A',  
            black: '#211A1A', 
            gray: '#E9E9E9',
            lightGray: '#F3F4F6',
            white: '#FFFFFF'
          },
          fonts: {
            heading: '"League Spartan", sans-serif',
            body: '"Inter", sans-serif'
          }
        };

        const CHART_COLORS = [
          { stroke: '#054E9A', fill: '#dbeafe', name: 'Electric Blue' },    
          { stroke: '#007C27', fill: '#dcfce7', name: 'La Salle Green' },     
          { stroke: '#211A1A', fill: '#f3f4f6', name: 'Eerie Black' },   
          { stroke: '#ea580c', fill: '#ffedd5', name: 'Orange' },  
          { stroke: '#9333ea', fill: '#f3e8ff', name: 'Purple' }   
        ];

        const PACKAGING_TYPES = ['Retail', 'Box/ Crate', 'Cube crate', 'Pallet'];

        const DEFAULT_CRITERIA = [
          'General Quality', 'Taste', 'Visual Appearance', 'Color',
          'Smell / Aroma', 'Texture / Firmness', 'Humidity / Condensation',
          'Dehydration / Shriveling', 'Moulds / Decay', 'Internal Browning'
        ];

        // --- HULPFUNCTIES ---
        const getStageIcon = (name) => {
          const n = name?.toLowerCase() || '';
          if (n.includes('farm') || n.includes('harvest') || n.includes('oogst')) return <Tractor size={14} color={BRAND.colors.black} />;
          if (n.includes('sea')) return <Ship size={14} color={BRAND.colors.black} />;
          if (n.includes('air')) return <Plane size={14} color={BRAND.colors.black} />;
          if (n.includes('storage') || n.includes('dc')) return <Warehouse size={14} color={BRAND.colors.black} />;
          if (n.includes('store') || n.includes('retail')) return <Store size={14} color={BRAND.colors.black} />;
          if (n.includes('consumer') || n.includes('eat')) return <Utensils size={14} color={BRAND.colors.black} />;
          if (n.includes('pack') && !n.includes('transport')) return <Factory size={14} color={BRAND.colors.black} />;
          return <Truck size={14} color={BRAND.colors.black} />;
        };

        const formatRange = (start, end, unit) => {
          if (start && end && start !== end) return `${start}-${end}${unit}`;
          if (start) return `${start}${unit}`;
          return `-`;
        };

        const formatDateToDDMMYYYY = (dateStr) => {
          if (!dateStr) return '-';
          const parts = dateStr.split('-');
          if (parts.length !== 3) return dateStr;
          return `${parts[2]}/${parts[1]}/${parts[0]}`;
        };

        // --- COMPONENTEN ---
        const RichTextEditor = ({ value, onChange, placeholder }) => {
          const editorRef = useRef(null);

          useEffect(() => {
            if (editorRef.current && value !== editorRef.current.innerHTML) {
              editorRef.current.innerHTML = value || '';
            }
          }, [value]);

          const handleInput = () => {
            if (editorRef.current) onChange(editorRef.current.innerHTML);
          };

          const execCmd = (cmd) => {
            document.execCommand(cmd, false, null);
            editorRef.current.focus();
            handleInput();
          };

          return (
            <div className="border border-slate-200 rounded-md overflow-hidden bg-white focus-within:border-green-600 focus-within:ring-2 focus-within:ring-green-100 transition flex flex-col h-full min-h-[120px]">
              <div className="bg-slate-50 border-b border-slate-200 p-1 flex gap-1 shrink-0">
                <button type="button" onClick={() => execCmd('bold')} className="p-1.5 hover:bg-slate-200 rounded text-slate-700 w-8 flex justify-center items-center"><Bold size={16}/></button>
                <button type="button" onClick={() => execCmd('italic')} className="p-1.5 hover:bg-slate-200 rounded text-slate-700 w-8 flex justify-center items-center"><Italic size={16}/></button>
                <button type="button" onClick={() => execCmd('underline')} className="p-1.5 hover:bg-slate-200 rounded text-slate-700 w-8 flex justify-center items-center"><Underline size={16}/></button>
                <div className="w-px bg-slate-300 mx-1 my-1"></div>
                <button type="button" onClick={() => execCmd('insertUnorderedList')} className="p-1.5 hover:bg-slate-200 rounded text-slate-700 w-8 flex justify-center items-center"><List size={16}/></button>
              </div>
              <div
                ref={editorRef}
                contentEditable
                onInput={handleInput}
                onBlur={handleInput}
                className="p-3 outline-none rich-text-editor text-sm font-sans flex-1 overflow-y-auto min-h-[100px]"
                data-placeholder={placeholder}
              />
            </div>
          );
        };

        const SupplyChainFlow = ({ chain }) => {
          if (!chain || chain.length === 0) return null;
          
          return (
            <div className="grid grid-cols-6 gap-2 w-full font-sans mt-4 mb-2 pb-2">
              {chain.map((step, idx) => {
                return (
                  <div key={idx} className="relative flex flex-col items-center w-full">
                    {/* Pijl naar het volgende item */}
                    {(idx + 1) % 6 !== 0 && idx !== chain.length - 1 && (
                      <div className="absolute top-10 -right-[12px] flex items-center justify-center z-10 text-gray-300">
                        <ChevronRight size={16} />
                      </div>
                    )}
                    <div className="w-full flex flex-col items-center bg-white border border-gray-200 rounded-lg shadow-sm p-1.5 relative min-h-[5.5rem]">
                       <div className="absolute top-0 left-0 w-full h-1" style={{backgroundColor: idx % 2 === 0 ? BRAND.colors.green : BRAND.colors.blue}}></div>
                       <div className="bg-gray-50 p-1.5 rounded-full mb-1 flex-shrink-0 mt-1">{getStageIcon(step.stage || '')}</div>
                       <div className="text-[8px] font-bold text-center uppercase mb-1 flex-grow flex items-center justify-center leading-tight w-full break-words px-1 overflow-hidden">{step.stage || '-'}</div>
                       <div className="w-full border-t border-dotted border-gray-200 my-0.5"></div>
                       <div className="flex flex-col justify-center w-full text-[8px] gap-0.5">
                          <span className="flex items-center justify-center gap-0.5 font-bold text-gray-700 whitespace-nowrap"><Thermometer size={8} className="text-red-500"/>{formatRange(step.tempStart, step.tempEnd, '°C')}</span>
                          <span className="flex items-center justify-center gap-0.5 text-gray-500 whitespace-nowrap"><Clock size={8}/>{formatRange(step.daysStart, step.daysEnd, 'd')}</span>
                       </div>
                    </div>
                    <div className="h-8 w-full flex justify-center items-start mt-1 relative">
                        {step.action === 'pack' && <div className="flex flex-col items-center"><div className="bg-green-100 text-green-700 rounded-full p-0.5 border border-green-200"><ArrowDown size={12} /></div><span className="text-[7px] font-bold text-green-700 uppercase mt-0.5">Packed</span></div>}
                        {step.action === 'unpack' && <div className="flex flex-col items-center"><div className="bg-red-100 text-red-700 rounded-full p-0.5 border border-red-200"><ArrowUp size={12} /></div><span className="text-[7px] font-bold text-red-700 uppercase mt-0.5">Opened</span></div>}
                    </div>
                  </div>
                )
              })}
            </div>
          );
        };

        // --- HOOFD APPLICATIE ---
        const App = () => {
          const [activeTab, setActiveTab] = useState('setup');
          const [activeGroupId, setActiveGroupId] = useState(1);
          const [isPreview, setIsPreview] = useState(false);
          const fileInputRef = useRef(null);

          const [pendingImageReplace, setPendingImageReplace] = useState(null);

          // --- DATA STATE ---
          const [project, setProject] = useState({
            reportTitle: 'Trial Proposal', 
            productName: '', processingType: 'Whole', type: '', origin: '', company: '', contactName: '', contactEmail: '', contactPhone: '', employee: '', trialTarget: '', currentChallenge: '',
            rrO2: '', rrCO2: '', rrTemp: '', startWeight: '', 
            acpO2: '', co2Max: '', co2Shock: '', co2ShockHours: '', tempMin: '', // Nieuwe optimale condities
            totalDuration: '', retailOpenDays: '', transportMode: '',
            criteria: [], // Verzoek: Standaard helemaal leeg
            date: new Date().toISOString().split('T')[0], packingDate: new Date().toISOString().split('T')[0],
            logo: 'https://cdn.prod.website-files.com/68b594c756c22085ddc6c1ea/68b59ba2f027bfeecd25261b_PerfoTec%20logo.png', clientLogo: null, startImage: null, coverImage: null,
            maturityStage: '', postHarvestTreatment: '',
            defectsMatrix: [] // Verzoek: Standaard leeg
          });

          const [supplyChain, setSupplyChain] = useState([
            { stage: 'Farm / Harvest', tempStart: '15', tempEnd: '', daysStart: '0.5', daysEnd: '', action: 'none' },
            { stage: 'Packing House', tempStart: '12', tempEnd: '', daysStart: '1', daysEnd: '', action: 'pack' },
            { stage: 'Transport by road', tempStart: '6', tempEnd: '', daysStart: '2', daysEnd: '', action: 'none' },
            { stage: 'Importer / Processor', tempStart: '8', tempEnd: '', daysStart: '1', daysEnd: '', action: 'none' },
            { stage: 'Retail Store', tempStart: '18', tempEnd: '', daysStart: '4', daysEnd: '', action: 'none' },
            { stage: 'Consumer (Open Pack)', tempStart: '20', tempEnd: '', daysStart: '2', daysEnd: '', action: 'unpack' }
          ]);

          const [groups, setGroups] = useState([
            {
              id: 1, name: 'Control',
              specs: { packaging: 'Retail', material: 'BOPP', length: '', width: '', height: '', holes: '2', holeSize: '6000', sampleCount: 3 },
              measurements: [{ day: 0 }, { day: 5 }],
              predictedImage: null 
            },
            {
              id: 2, name: 'PerfoTec Laser',
              specs: { packaging: 'Retail', material: 'BOPP', length: '', width: '', height: '', holes: '4', holeSize: '95', sampleCount: 3 },
              measurements: [{ day: 0 }, { day: 5 }],
              predictedImage: null 
            }
          ]);

          const [proposal, setProposal] = useState({ 
            intro: 'To extend the shelf life and maintain the optimal quality of your product, we propose conducting a comparative MAP (Modified Atmosphere Packaging) trial. By utilizing PerfoTec\'s advanced respiration and laser technology, we aim to create the perfect microclimate within the packaging.', 
            expectedOutcomes: '<ul><li>Extension of shelf life by X days.</li><li>Reduction of moisture loss and weight loss.</li><li>Maintenance of natural color and firmness.</li></ul>', 
            requirements: '<ul><li>Provide current packaging material for the control group.</li><li>The product must be transported under cooled conditions.</li></ul>' 
          });
          
          const [newCriteria, setNewCriteria] = useState('');

          const calcUnpackingDate = () => {
            const baseDate = project.packingDate || project.date;
            const duration = parseInt(project.totalDuration) || 0;
            if (baseDate && duration) {
               const d = new Date(baseDate);
               d.setDate(d.getDate() + duration);
               const day = String(d.getDate()).padStart(2, '0');
               const month = String(d.getMonth() + 1).padStart(2, '0');
               const year = d.getFullYear();
               return `${day}/${month}/${year}`; 
            }
            return '-';
          };
          
          const calcRetailDate = () => {
            const baseDate = project.packingDate || project.date;
            const duration = parseInt(project.totalDuration) || 0;
            const retailDays = parseInt(project.retailOpenDays) || 0;
            if (baseDate && (duration || retailDays)) {
               const d = new Date(baseDate);
               d.setDate(d.getDate() + duration + retailDays);
               const day = String(d.getDate()).padStart(2, '0');
               const month = String(d.getMonth() + 1).padStart(2, '0');
               const year = d.getFullYear();
               return `${day}/${month}/${year}`; 
            }
            return '-';
          };

          // --- HANDLERS ---
          const handleImgUpload = (e, field) => { 
             const f = e.target.files[0]; 
             if(f) { 
                const r = new FileReader(); 
                r.onloadend = () => { setProject(p => ({...p, [field]: r.result})); }; 
                r.readAsDataURL(f); 
             }
          };

          const handlePredictedImageUpload = (e, groupId) => { 
            const file = e.target.files[0]; 
            if(file) { 
              const group = groups.find(g => g.id === groupId);
              const reader = new FileReader(); 
              reader.onloadend = () => {
                 if (group && group.predictedImage) {
                    setPendingImageReplace({ groupId: groupId, result: reader.result });
                 } else {
                    setGroups(prev => prev.map(g => g.id === groupId ? { ...g, predictedImage: reader.result } : g)); 
                 }
              };
              reader.readAsDataURL(file); 
              e.target.value = '';
            }
          };

          const confirmReplaceImage = () => {
            setGroups(prev => prev.map(g => g.id === pendingImageReplace.groupId ? { ...g, predictedImage: pendingImageReplace.result } : g));
            setPendingImageReplace(null);
          };

          const removePredictedImage = (groupId) => {
            setGroups(prev => prev.map(g => g.id === groupId ? { ...g, predictedImage: null } : g));
          };

          const handleProjectChange = (f, v) => setProject(p => ({...p, [f]: v}));
          
          const handleDurationChange = (e) => {
            setProject(p => ({...p, totalDuration: e.target.value}));
          };

          const addDefectRow = () => {
            setProject(p => ({ ...p, defectsMatrix: [...(p.defectsMatrix || []), { id: Date.now(), defect: '', cause: '', effectMHP: '', effectMAP: '' }] }));
          };
          const updateDefectRow = (id, field, val) => {
            setProject(p => ({ ...p, defectsMatrix: p.defectsMatrix.map(r => r.id === id ? { ...r, [field]: val } : r) }));
          };
          const removeDefectRow = (id) => {
            setProject(p => ({ ...p, defectsMatrix: p.defectsMatrix.filter(r => r.id !== id) }));
          };

          const exportData = () => {
            const exportGroups = groups.map(g => ({
              ...g,
              measurements: (g.measurements || []).map(m => ({
                 day: m.day,
                 samples: Array.from({length: g.specs?.sampleCount || 3}, (_, i) => ({ id: Date.now()+i, o2: '', co2: '', weight: '' })),
                 quality: 9,
                 notes: '',
                 images: [],
                 qualityParams: [],
                 evaluateQuality: true
              }))
            }));

            const data = { project, supplyChain, groups: exportGroups, proposal };
            const blob = new Blob([JSON.stringify(data)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a'); a.href = url; 
            a.download = `perfotec_proposal_${project.company ? project.company.replace(/[^a-z0-9]/gi, '_').toLowerCase() : 'client'}.json`; 
            a.click();
          };

          const importData = (e) => { 
            const file = e.target.files[0]; if(!file) return; 
            const reader = new FileReader(); 
            reader.onload = (ev) => { 
                try { 
                    const d = JSON.parse(ev.target.result); 
                    if(d.isPerfoTecIntake) {
                       const client = d.client || {}; const prod = d.products?.[0] || {};
                       setProject(p => ({ ...p, 
                         company: client.companyName||'', street: client.street||'', houseNumber: client.houseNumber||'', zipCode: client.zipCode||'', city: client.city||'', country: client.country||'', contactName: client.contactName||'', contactRole: client.role||'', contactEmail: client.email||'', contactPhone: client.phone||'', logo: client.logo||p.logo, productName: prod.name||'', processingType: prod.processingType||'Whole', maturityStage: prod.maturityStage||'', postHarvestTreatment: prod.postHarvestTreatment||'', currentChallenge: prod.currentChallenge||'', trialTarget: prod.targetGoal||'', transportMode: prod.transportMode || (prod.transportModes?.[0] || ''), criteria: prod.qualityCriteria||[], startImage: prod.photo||null,
                         startWeight: prod.weight || p.startWeight 
                       }));
                       if (prod.supplyChain) setSupplyChain(prod.supplyChain);
                       setGroups(p => { const ug = [...p]; if(ug[0]) { ug[0].specs = { ...ug[0].specs, packaging: prod.packagingType||'Retail', material: prod.material||'', length: prod.length||'', width: prod.width||'', height: prod.height||'' }; } return ug; });
                    } else {
                       if(d.project) {
                           setProject(p => ({
                               ...p, 
                               ...d.project, 
                               co2Shock: d.project.co2Shock || d.project.co2Burst || '', // Backwards compatibility
                               packingDate: d.project.packingDate || d.project.date || new Date().toISOString().split('T')[0], 
                               transportMode: d.project.transportMode || '',
                               startWeight: d.project.startWeight || d.groups?.[0]?.specs?.startWeight || ''
                           })); 
                       }
                       if(d.supplyChain) setSupplyChain(d.supplyChain); 
                       if(d.groups) {
                           const proposalGroups = d.groups.map(g => ({
                               ...g,
                               measurements: (g.measurements || []).map(m => ({ day: m.day }))
                           }));
                           setGroups(proposalGroups);
                       }
                       if(d.proposal) setProposal(d.proposal);
                    }
                } catch(err){ alert("Error loading file."); } 
            }; reader.readAsText(file); 
          };

          const handleGroupChange = (id, section, field, value) => {
            setGroups(prev => prev.map(g => {
              if (g.id !== id) return g;
              if (section === 'name') return { ...g, name: value };
              if (section === 'specs') return { ...g, specs: { ...g.specs, [field]: value } };
              return g;
            }));
          };

          const toggleCriteria = (c) => setProject(p => ({ ...p, criteria: p.criteria?.includes(c) ? p.criteria.filter(x => x !== c) : [...(p.criteria||[]), c] }));
          const addNewCriteria = () => { if(newCriteria && !(project.criteria||[]).includes(newCriteria)) { toggleCriteria(newCriteria); setNewCriteria(''); }};
          const handleTransportModeToggle = (mode) => {
            setProject(p => ({ ...p, transportMode: p.transportMode === mode ? '' : mode }));
          };

          // Supply Chain
          const addChainStep = () => setSupplyChain([...supplyChain, { stage: '', tempStart: '', tempEnd: '', daysStart: '', daysEnd: '', action: 'none' }]);
          const updateChainStep = (i, f, v) => { const n = [...supplyChain]; n[i][f] = v; setSupplyChain(n); };
          const removeChainStep = (i) => setSupplyChain(supplyChain.filter((_, idx) => idx !== i));
          const moveChainStep = (i, dir) => { const n = [...supplyChain]; if(dir==='up' && i>0){ [n[i], n[i-1]] = [n[i-1], n[i]]; } else if(dir==='down' && i<n.length-1){ [n[i], n[i+1]] = [n[i+1], n[i]]; } setSupplyChain(n); };

          // Group Handling
          const addNewVariant = () => {
            const newId = Math.max(...groups.map(g => g.id), 0) + 1;
            setGroups([...groups, { 
                id: newId, 
                name: `Variant ${groups.length + 1}`, 
                specs: { ...groups[0].specs }, 
                measurements: [...groups[0].measurements],
                predictedImage: null
            }]);
            setActiveGroupId(newId);
          };

          const duplicateGroup = (id) => { const org = groups.find(g => g.id === id); const newId = Math.max(...groups.map(g => g.id), 0) + 1; setGroups(p => [...p, { ...org, id: newId, name: `${org.name} (Copy)` }]); setActiveGroupId(newId); };
          const removeGroup = (id) => { 
            if(groups.length > 1) { 
                setGroups(p => {
                    const newGroups = p.filter(g => g.id !== id);
                    if (activeGroupId === id) setActiveGroupId(newGroups[0].id);
                    return newGroups;
                });
            }
          };

          // Days handling for groups
          const addEvaluationDay = () => {
              const lastDay = groups[0]?.measurements?.length > 0 ? Math.max(...groups[0].measurements.map(m => m.day)) : 0;
              const newDay = lastDay + 1;
              setGroups(prev => prev.map(g => ({
                  ...g,
                  measurements: [...(g.measurements || []), { day: newDay }].sort((a,b) => a.day - b.day)
              })));
          };

          const removeEvaluationDay = (dayToRemove) => {
              setGroups(prev => prev.map(g => ({
                  ...g,
